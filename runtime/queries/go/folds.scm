; Definitions
[
  (function_declaration)
  (method_declaration)
  (func_literal)
] @fold

; Control flow
[
  (if_statement)
  (for_statement)
  (expression_switch_statement)
  (type_switch_statement)
  (select_statement)
] @fold

; Types
[
  (struct_type)
  (interface_type)
] @fold

; Blocks and literals
[
  (block)
  (literal_value)
] @fold

; Declarations
[
  (const_declaration)
  (var_declaration)
  (import_declaration)
] @fold

; Other
[
  (comment)
] @fold
