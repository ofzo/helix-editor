; Definitions
[
  (function_declaration)
  (function)
  (arrow_function)
  (method_definition)
  (generator_function_declaration)
  (class_declaration)
  (class)
] @fold

; Control flow
[
  (if_statement)
  (else_clause)
  (switch_statement)
  (switch_case)
  (switch_default)
  (for_statement)
  (for_in_statement)
  (while_statement)
  (do_statement)
  (try_statement)
  (catch_clause)
  (finally_clause)
] @fold

; Data structures
[
  (object)
  (array)
  (object_pattern)
  (array_pattern)
  (statement_block)
  (class_body)
] @fold

; Other
[
  (template_string)
  (export_statement)
  (import_statement)
  (named_imports)
  (comment)
] @fold
